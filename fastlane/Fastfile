default_platform(:ios)

# --- Project facts (from project.yml — the XcodeGen source of truth) ---
APP_SCHEME     = "ComeOnBackPager"
TEAM_ID        = "9XKN747L88"
APP_IDENTIFIER = "co.amalgamated.ComeOnBackPager"
APP_TARGET     = "ComeOnBack Pager"           # target/display name has a space
APP_NAME       = "ComeOnBack Pager"

# Anchor every path to the repo root, NOT the process CWD — fastlane's working
# directory for Fastfile Ruby changed between 2.236 and 2.237, which broke the
# first CI run. FastlaneFolder.path is stable across versions.
ROOT         = File.expand_path("..", FastlaneCore::FastlaneFolder.path)
PROJECT_PATH = File.join(ROOT, "ComeOnBack Pager.xcodeproj")   # generated — never committed
BUILD_DIR    = File.join(ROOT, "build")

# Version facts come from project.yml (not the generated pbxproj) so lanes work
# before generation and read the committed truth.
def marketing_version
  yml = File.read(File.join(ROOT, "project.yml"))
  yml[/MARKETING_VERSION:\s*"?([^"\s]+)"?/, 1] or
    UI.user_error!("Couldn't read MARKETING_VERSION from project.yml")
end

platform :ios do
  # The .xcodeproj is generated (XcodeGen). Every build lane regenerates first so a
  # fresh checkout — CI or local — never depends on a stale/absent project.
  private_lane :generate_project do
    sh("command -v xcodegen >/dev/null || { echo 'xcodegen not found (brew install xcodegen)'; exit 1; }")
    sh("cd #{ROOT.shellescape} && xcodegen generate")
  end

  # App Store Connect API-key auth from env (ASC_KEY_CONTENT = raw .p8 PEM, no file on
  # disk; ASC_KEY_P8 = filepath fallback). scripts/pager-release.sh loads these from
  # 1Password.
  private_lane :configure_asc_api_key do
    args = {
      key_id:    ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    }
    if (content = ENV["ASC_KEY_CONTENT"]) && !content.empty?
      args[:key_content] = content
    elsif (path = ENV["ASC_KEY_P8"]) && !path.empty?
      args[:key_filepath] = path
    else
      UI.user_error!("No App Store Connect key. Set ASC_KEY_CONTENT or ASC_KEY_P8 " \
                     "(plus ASC_KEY_ID and ASC_ISSUER_ID), or run scripts/pager-release.sh " \
                     "to load them from 1Password.")
    end
    app_store_connect_api_key(**args)
  end

  # Refuse to ship a binary built with a BETA Xcode — App Store Review rejects those.
  private_lane :ensure_release_toolchain do
    next if ENV["ALLOW_BETA_XCODE"] == "1"
    dev_dir = `xcode-select -p`.strip
    if dev_dir.downcase.include?("beta")
      UI.user_error!("Refusing: selected Xcode looks like a BETA (#{dev_dir}). App Store " \
                     "Review rejects beta-built binaries. Select a release Xcode or set " \
                     "ALLOW_BETA_XCODE=1.")
    end
  end

  desc "Prove the App Store Connect API key authenticates — no build, no upload."
  lane :verify_asc do
    configure_asc_api_key
    UI.message("Authenticated to App Store Connect. Reading latest TestFlight build…")
    begin
      n = latest_testflight_build_number(app_identifier: APP_IDENTIFIER)
      UI.success("ASC auth OK — latest TestFlight build number: #{n}")
    rescue => e
      UI.success("ASC auth OK — could not read latest build (#{e.message})")
    end
  end

  desc "One-time: verify the App Store Connect app record exists (creation needs Apple ID auth — " \
       "the public ASC API can't create app records, so produce/ASC-web is a user-side step)."
  lane :create_app do
    configure_asc_api_key
    api_key = lane_context[SharedValues::APP_STORE_CONNECT_API_KEY]
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.from(hash: api_key)
    app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
    if app
      UI.success("ASC app record exists: '#{app.name}' (#{APP_IDENTIFIER}), Apple ID #{app.id}, " \
                 "SKU #{app.sku || 'n/a'} — nothing to create.")
    else
      UI.user_error!("No ASC app record for #{APP_IDENTIFIER}. Create it once (API keys can't): " \
                     "ASC web → My Apps → + → New App (name '#{APP_NAME}', bundle id " \
                     "#{APP_IDENTIFIER}, SKU COMEONBACKPAGER), or interactively: " \
                     "fastlane produce -u <apple-id> -a #{APP_IDENTIFIER} --app_name '#{APP_NAME}'")
    end
  end

  desc "Build and upload to TestFlight (local: automatic signing). Creds via scripts/pager-release.sh."
  lane :beta do
    configure_asc_api_key
    build_appstore_ipa
    upload_to_testflight(skip_waiting_for_build_processing: true)
  end

  desc "Build a signed App Store .ipa without uploading — validates signing locally (no ASC key)."
  lane :build_only do
    build_appstore_ipa
  end

  # ---------------------------------------------------------------------------
  # App Store release. Agentic flow (mirrors the ios repo):
  #   beta → soak on TestFlight → prepare → (review precheck) → submit
  #   → Apple approves → you click Release in ASC.
  # This app distributes as an UNLISTED app (install by link, never searchable) —
  # the unlisted request form is a one-time user-side step; the pipeline is identical.
  # ---------------------------------------------------------------------------

  desc "Prepare the App Store version: push repo metadata (+screenshots unless " \
       "screenshots:false), attach the soaked build, precheck — STOP before submit."
  lane :prepare do |options|
    configure_asc_api_key
    version = options[:version] || marketing_version
    build   = (options[:build] ||
               latest_testflight_build_number(app_identifier: APP_IDENTIFIER, version: version)).to_s
    skip_shots = options[:screenshots].to_s == "false"
    UI.message("Preparing App Store version #{version} with build #{build} (no submit)…")
    upload_to_app_store(
      app_identifier:        APP_IDENTIFIER,
      app_version:           version,
      build_number:          build,
      skip_binary_upload:    true,
      skip_metadata:         false,
      skip_screenshots:      skip_shots,
      overwrite_screenshots: !skip_shots,
      submit_for_review:     false,
      automatic_release:     false,
      force:                 true,
      precheck_include_in_app_purchases: false,
    )
    # include_in_app_purchases must be off under API-key auth (precheck limitation)
    precheck(app_identifier: APP_IDENTIFIER, default_rule_level: :error,
             include_in_app_purchases: false)
    UI.success("Version #{version}/#{build} prepared + precheck passed. Review in ASC, then: " \
               "scripts/pager-release.sh submit")
  end

  desc "Submit the prepared App Store version for review (agent-confirmed). Refuses beta Xcode."
  lane :submit do
    ensure_release_toolchain
    configure_asc_api_key
    upload_to_app_store(
      app_identifier:     APP_IDENTIFIER,
      skip_binary_upload: true,
      skip_metadata:      true,
      skip_screenshots:   true,
      submit_for_review:  true,
      automatic_release:  false,
      force:              true,
    )
    UI.success("Submitted for App Store Review. After approval, click Release in ASC.")
  end

  # ---------------------------------------------------------------------------
  # CI. GitHub Actions on macos-15 (see .github/workflows/):
  #   ci.yml      — unsigned compile check (raw xcodebuild, no fastlane)
  #   release.yml — v<version> tag → beta_ci → TestFlight
  #   appstore.yml — manual gated prepare/submit
  # ---------------------------------------------------------------------------

  desc "Build a match-signed App Store .ipa and upload to TestFlight. upload:false = dry run."
  lane :beta_ci do |options|
    upload = options.fetch(:upload, true)
    setup_ci                    # no-op unless CI=true; makes the temp keychain match imports into
    configure_asc_api_key
    generate_project
    # apply_match_signing flips the target to manual signing IN THIS CHECKOUT only.
    # Snapshot/restore the (generated) pbxproj so every path leaves the tree clean.
    pbxproj = File.join(PROJECT_PATH, "project.pbxproj")
    pbxproj_before = File.read(pbxproj)
    begin
      apply_match_signing
      build_app(
        project:        PROJECT_PATH,
        scheme:         APP_SCHEME,
        export_method:  "app-store",
        export_options: {
          signingStyle:         "manual",
          teamID:               TEAM_ID,
          provisioningProfiles: {
            APP_IDENTIFIER => ENV["sigh_#{APP_IDENTIFIER}_appstore_profile-name"],
          },
        },
        output_directory: BUILD_DIR,
        output_name:      "ComeOnBackPager.ipa",
        clean:            true,
      )
      if upload
        upload_to_testflight(skip_waiting_for_build_processing: true)
        UI.success("Uploaded match-signed build to TestFlight.")
      else
        UI.success("Dry run: match-signed build/ComeOnBackPager.ipa built, upload skipped.")
      end
    ensure
      File.write(pbxproj, pbxproj_before)
    end
  end

  desc "Local validation of the CI signing path: match-signed .ipa, no upload."
  lane :build_only_ci do
    beta_ci(upload: false)
  end

  desc "One-time bootstrap / rotation: fetch-or-create the match App Store profile for the " \
       "pager in the shared certs repo (read-WRITE — run locally, never in CI)."
  lane :certs do
    configure_asc_api_key
    match(
      type:           "appstore",
      app_identifier: [APP_IDENTIFIER],
      readonly:       false,
    )
    UI.success("match cert + pager profile are in the certs repo. CI (beta_ci) consumes them readonly.")
  end

  # Install the match cert+profile, then flip the target to manual signing with that
  # profile — in THIS checkout only (regenerate to reset). readonly on CI.
  private_lane :apply_match_signing do
    match(
      type:           "appstore",
      app_identifier: [APP_IDENTIFIER],
      readonly:       ENV["CI"] == "true",
    )
    update_code_signing_settings(
      path:                  PROJECT_PATH,
      targets:               [APP_TARGET],
      build_configurations:  ["Release"],
      use_automatic_signing: false,
      team_id:               TEAM_ID,
      code_sign_identity:    "Apple Distribution",
      bundle_identifier:     APP_IDENTIFIER,
      profile_name:          ENV["sigh_#{APP_IDENTIFIER}_appstore_profile-name"],
    )
  end

  # Shared archive+export for the local lanes: automatic signing mints the App Store
  # distribution profile non-interactively (-allowProvisioningUpdates).
  private_lane :build_appstore_ipa do
    generate_project
    build_app(
      project:        PROJECT_PATH,
      scheme:         APP_SCHEME,
      export_method:  "app-store",
      export_options: {
        signingStyle: "automatic",
        teamID:       TEAM_ID,
      },
      xcargs:           "-allowProvisioningUpdates",
      export_xcargs:    "-allowProvisioningUpdates",
      output_directory: BUILD_DIR,
      output_name:      "ComeOnBackPager.ipa",
      clean:            true,
    )
  end
end
